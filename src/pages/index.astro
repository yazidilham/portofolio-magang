<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ahmad Yazid Ilham Zhulfiqor — Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #fafaf8;
      --bg-card: #ffffff;
      --bg-secondary: #f0efe9;
      --text: #1a1a1a;
      --text-secondary: #6b6b6b;
      --text-tertiary: #b0b0a8;
      --border: rgba(0,0,0,0.08);
      --border-strong: rgba(0,0,0,0.18);
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0f0f0e;
        --bg-card: #181817;
        --bg-secondary: #1e1e1c;
        --text: #f0ede8;
        --text-secondary: #888880;
        --text-tertiary: #4a4a44;
        --border: rgba(255,255,255,0.08);
        --border-strong: rgba(255,255,255,0.18);
      }
    }

    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    svg { display: inline-block; vertical-align: middle; flex-shrink: 0; }

    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; justify-content: space-between; align-items: center;
      padding: 0 3rem; height: 60px;
      background: var(--bg);
      border-bottom: 0.5px solid var(--border);
    }
    .nav-logo { font-family: 'Instrument Serif', serif; font-size: 1.1rem; color: var(--text); text-decoration: none; letter-spacing: 0.01em; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { font-size: 13px; color: var(--text-secondary); text-decoration: none; transition: color 0.2s; letter-spacing: 0.01em; }
    .nav-links a:hover { color: var(--text); }

    /* ── HERO ── */
    #hero {
      min-height: calc(100vh - 60px);
      display: grid;
      grid-template-columns: 1fr 420px;
      align-items: center;
      padding: 0 3rem;
      gap: 4rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero-text { }

    .hero-tag {
      font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--text-tertiary); margin-bottom: 2rem;
      display: flex; align-items: center; gap: 12px;
    }
    .hero-tag::before { content: ''; width: 32px; height: 1px; background: var(--text-tertiary); }

    .hero-name {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(3rem, 5.5vw, 5rem);
      line-height: 1.0;
      letter-spacing: -0.025em;
      margin-bottom: 1.75rem;
    }
    .hero-name em { font-style: italic; color: var(--text-secondary); display: block; }

    .hero-desc {
      font-size: 16px; color: var(--text-secondary);
      line-height: 1.75; max-width: 440px; margin-bottom: 1rem;
    }

    .hero-meta {
      display: flex; align-items: center; gap: 12px;
      font-size: 13px; color: var(--text-tertiary); margin-bottom: 3rem; flex-wrap: wrap;
    }
    .meta-item { display: flex; align-items: center; gap: 5px; }
    .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--text-tertiary); }

    .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

    .btn-primary {
      padding: 12px 28px; background: var(--text); color: var(--bg);
      border: none; border-radius: 8px; font-size: 14px; font-weight: 500;
      font-family: 'DM Sans', sans-serif; cursor: pointer; text-decoration: none;
      transition: opacity 0.2s; display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-primary:hover { opacity: 0.8; }

    .btn-outline {
      padding: 12px 28px; background: transparent; color: var(--text);
      border: 0.5px solid var(--border-strong); border-radius: 8px;
      font-size: 14px; font-weight: 500; font-family: 'DM Sans', sans-serif;
      cursor: pointer; text-decoration: none; transition: background 0.2s;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-outline:hover { background: var(--bg-secondary); }

    /* ── HERO PHOTO ── */
    .hero-visual {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .photo-frame {
      position: relative;
      width: 360px;
      height: 440px;
    }

    .photo-bg-shape {
      position: absolute;
      inset: 0;
      border-radius: 200px 200px 160px 160px;
      background: var(--bg-secondary);
      border: 0.5px solid var(--border);
    }

    .hero-photo {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 320px;
      height: 400px;
      object-fit: cover;
      object-position: top center;
      border-radius: 160px 160px 120px 120px;
      display: block;
    }

    /* ── COMMON ── */
    hr { border: none; border-top: 0.5px solid var(--border); }

    section.content-section { padding: 4rem 3rem; max-width: 1200px; margin: 0 auto; }

    .section-label {
      font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--text-tertiary); margin-bottom: 2.5rem;
      display: flex; align-items: center; gap: 12px;
    }
    .section-label::before { content: ''; width: 24px; height: 1px; background: var(--text-tertiary); }

    /* ── ABOUT ── */
    .about-text { font-family: 'Instrument Serif', serif; font-size: 1.4rem; line-height: 1.75; max-width: 640px; }
    .about-text em { font-style: italic; color: var(--text-secondary); }

    .about-info {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 0.5px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      margin-top: 3rem;
      max-width: 640px;
    }
    .info-item { padding: 1.25rem 1.5rem; background: var(--bg-card); display: flex; flex-direction: column; gap: 6px; }
    .info-label { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-tertiary); }
    .info-val { font-size: 14px; font-weight: 500; }

    /* ── SKILLS ── */
    .skills-grid { display: flex; flex-wrap: wrap; gap: 10px; }
    .skill-pill {
      padding: 10px 20px; border: 0.5px solid var(--border); border-radius: 40px;
      font-size: 13px; color: var(--text-secondary); background: var(--bg-card);
      transition: all 0.2s; cursor: default;
    }
    .skill-pill:hover { border-color: var(--border-strong); color: var(--text); background: var(--bg-secondary); }

    /* ── PROJECTS ── */
    .projects-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1px; background: var(--border);
      border: 0.5px solid var(--border); border-radius: 16px; overflow: hidden;
    }
    .proj-card { padding: 2rem; background: var(--bg-card); transition: background 0.2s; }
    .proj-card:hover { background: var(--bg-secondary); }
    .proj-num { font-size: 11px; color: var(--text-tertiary); margin-bottom: 1rem; letter-spacing: 0.1em; }
    .proj-title { font-family: 'Instrument Serif', serif; font-size: 1.2rem; margin-bottom: 0.6rem; line-height: 1.3; }
    .proj-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.25rem; }
    .proj-tech { display: flex; gap: 6px; flex-wrap: wrap; }
    .tech-badge {
      font-size: 11px; padding: 4px 12px; border-radius: 40px;
      background: var(--bg-secondary); color: var(--text-secondary); border: 0.5px solid var(--border);
    }

    /* ── CONTACT ── */
    .contact-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
    .contact-heading {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(1.75rem, 3.5vw, 2.75rem);
      line-height: 1.15; margin-bottom: 1rem;
    }
    .contact-sub { font-size: 14px; color: var(--text-secondary); line-height: 1.7; }
    .contact-links { display: flex; flex-direction: column; gap: 10px; }
    .contact-link {
      display: flex; align-items: center; gap: 12px; font-size: 14px;
      color: var(--text-secondary); text-decoration: none;
      padding: 14px 18px; border: 0.5px solid var(--border); border-radius: 10px;
      background: var(--bg-card);
      transition: all 0.2s;
    }
    .contact-link:hover { border-color: var(--border-strong); color: var(--text); background: var(--bg-secondary); }

    /* ── FOOTER ── */
    footer {
      padding: 2rem 3rem; border-top: 0.5px solid var(--border);
      display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;
      max-width: 1200px; margin: 0 auto;
    }
    .footer-name { font-family: 'Instrument Serif', serif; font-size: 1rem; }
    .footer-copy { font-size: 12px; color: var(--text-tertiary); }

    /* ── ANIMATION ── */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    #hero { animation: fadeUp 0.7s ease both; }
    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      #hero { grid-template-columns: 1fr; min-height: unset; padding: 3rem 2rem 2rem; gap: 2rem; }
      .hero-visual { order: -1; }
      .photo-frame { width: 260px; height: 320px; }
      .hero-photo { width: 230px; height: 290px; }
      .projects-grid { grid-template-columns: 1fr; }
      .contact-inner { grid-template-columns: 1fr; gap: 2rem; }
      .about-info { grid-template-columns: 1fr; }
    }
    @media (max-width: 640px) {
      nav { padding: 0 1.5rem; }
      .nav-links { gap: 1.25rem; }
      section.content-section { padding: 3rem 1.5rem; }
      footer { padding: 1.5rem; }
      .hero-name { font-size: 2.5rem; }
    }
  </style>
</head>
